# Créer une représentation visuelle des connexions
connections = {}
for i in range(system.nbNodes):
    node = system.nodes[i]
    connections[node.name] = []
    for inp in node.inputs:
        source_node = system.nodes[inp.sourceNodeIndex]
        connections[node.name].append(source_node.name)

